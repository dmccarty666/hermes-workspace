db_path = '/home/dmccarty/.hermes/kanban/kanban.db'
# Create fresh DB with proper schema
conn = sqlite3.connect(db_path)
c = conn.cursor()
# Create tables based on typical kanban schema
c.execute('''CREATE TABLE IF NOT EXISTS boards (
    id TEXT PRIMARY KEY,
    name TEXT NOT NULL,
    created_at TEXT,
    updated_at TEXT
)''')
c.execute('''CREATE TABLE IF NOT EXISTS tasks (
    id TEXT PRIMARY KEY,
    board_id TEXT NOT NULL,
    title TEXT,
    body TEXT,
    status TEXT DEFAULT 'todo',
    assignee TEXT,
    priority INTEGER DEFAULT 0,
    created_at TEXT,
    updated_at TEXT,
    completed_at TEXT,
    FOREIGN KEY (board_id) REFERENCES boards(id)
)''')
c.execute('''CREATE TABLE IF NOT EXISTS comments (
    id TEXT PRIMARY KEY,
    task_id TEXT NOT NULL,
    author TEXT,
    content TEXT,
    created_at TEXT,
    FOREIGN KEY (task_id) REFERENCES tasks(id)
)''')
c.execute('''CREATE TABLE IF NOT EXISTS events (
    id TEXT PRIMARY KEY,
    task_id TEXT NOT NULL,
    event_type TEXT,
    data TEXT,
    created_at TEXT,
    FOREIGN KEY (task_id) REFERENCES tasks(id)
)''')
c.execute('''CREATE TABLE IF NOT EXISTS diagnostics (
    id TEXT PRIMARY KEY,
    task_id TEXT NOT NULL,
    severity TEXT,
    message TEXT,
    created_at TEXT,
    FOREIGN KEY (task_id) REFERENCES tasks(id)
)''')
# Create default board
c.execute(\"INSERT INTO boards (id, name, created_at, updated_at) VALUES ('default', 'default', datetime('now'), datetime('now'))\")
conn.commit()
conn.close()
print('DB created successfully')
print(f'Size: {os.path.getsize(db_path)} bytes')
