+import json, sys
+
+with open('/tmp/kanban_ls.json') as f:
+    cards = json.load(f)
+
+# Phase 5 cards
+p5 = [c for c in cards if 'PHASE 5' in c.get('title','') or 'PHASE-5' in c.get('title','') or 'Phase 5' in c.get('title','')]
+print("=== Phase 5 Cards ===")
+for c in p5:
+    print(f"  {c['id']:20s} {c['status']:10s} {c.get('assignee',''):15s} {c['title']}")
+
+# Gate cards
+print("\n=== Gate Cards ===")
+for c in cards:
+    if 'GATE' in c.get('title',''):
+        print(f"  {c['id']:20s} {c['status']:10s} {c.get('assignee',''):15s} {c['title']}")
+
+# Blocked cards
+print("\n=== Blocked Cards ===")
+blocked = [c for c in cards if c.get('status') == 'blocked']
+for c in blocked:
+    blocks = c.get('blocks', [])
+    reasons = [b.get('reason','') for b in blocks if b.get('reason')]
+    print(f"  {c['id']:20s} {c.get('assignee',''):15s} {c['title']}: {', '.join(reasons)}")
+
+# Review-required
+print("\n=== Review-Required ===")
+for c in cards:
+    blocks = c.get('blocks', [])
+    for b in blocks:
+        if b.get('reason') == 'review-required':
+            print(f"  {c['id']:20s} {c.get('assignee',''):15s} {c['title']}")
+
+# QA rejected
+print("\n=== QA Rejected ===")
+for c in cards:
+    blocks = c.get('blocks', [])
+    for b in blocks:
+        if b.get('reason', '').startswith('qa-rejected'):
+            print(f"  {c['id']:20s} {c.get('assignee',''):15s} {c['title']}: {b.get('reason','')}")
+
+print(f"\nTotal cards: {len(cards)}")
+print(f"Phase 5 cards: {len(p5)}")
+print(f"Blocked: {len(blocked)}")
