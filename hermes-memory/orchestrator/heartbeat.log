# Find task entries by looking for known patterns
# Tasks have IDs like t_085fa48b, t_3facf224, etc.
task_entries = {}
for m in re.finditer(r't_[a-f0-9]{8}', text):
    tid = m.group()
    # Get context around this ID
    start = max(0, m.start() - 200)
    end = min(len(text), m.end() + 200)
    context = text[start:end]
    # Extract title if present
    title_match = re.search(r'title\s*[=:]\s*["\']?([^"\']{1,200})["\']?', context)
    status_match = re.search(r'status\s*[=:]\s*["\']?([^"\']{1,50})["\']?', context)
    assignee_match = re.search(r'assignee\s*[=:]\s*["\']?([^"\']{1,50})["\']?', context)
    task_entries[tid] = {
        'title': title_match.group(1).strip() if title_match else None,
        'status': status_match.group(1).strip() if status_match else None,
        'assignee': assignee_match.group(1).strip() if assignee_match else None,
    }

print(f"Found {len(task_entries)} task entries in raw data")
